# Configuração para systemd (/etc/glpi-integration/env)
# Copie: sudo cp deploy/ubuntu/env.example /etc/glpi-integration/env
#        sudo chmod 600 /etc/glpi-integration/env
#        sudo nano /etc/glpi-integration/env

GLPI_API_STYLE=LEGACY_APIREST
GLPI_API_BASE_URL=http://192.168.1.98/apirest.php
GLPI_APP_TOKEN=
GLPI_USER_TOKEN=

GLPI_ITEMTYPE_STARLINK=Glpi\Asset\AssetDefinition/Starlink
GLPI_ITEMTYPE_CHIP=Glpi\Asset\AssetDefinition/Chip
GLPI_ITEMTYPE_CELULAR=Glpi\Asset\AssetDefinition/Celular

GLPI_SYNC_INPUT=

GLPI_API_KEY=
SPRING_PROFILES_ACTIVE=prod

SERVER_PORT=8081
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0
