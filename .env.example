# Copie para .env na raiz do projeto:  cp .env.example .env
# Edite com os valores do seu ambiente (Ubuntu / Docker).

# --- GLPI (obrigatório) ---
GLPI_API_STYLE=LEGACY_APIREST
# URL acessível DE DENTRO do container (use IP do servidor GLPI na rede)
# Se o GLPI está na mesma máquina Ubuntu que o Docker, pode usar host.docker.internal:
# GLPI_API_BASE_URL=http://host.docker.internal/apirest.php
GLPI_API_BASE_URL=http://192.168.1.98/apirest.php
GLPI_APP_TOKEN=
GLPI_USER_TOKEN=

# --- Itemtypes GLPI 11 (ajuste após GET /api/custom-assets/discover) ---
# No .env use uma barra invertida: Glpi\Asset\AssetDefinition/Starlink
GLPI_ITEMTYPE_STARLINK=Glpi\Asset\AssetDefinition/Starlink
GLPI_ITEMTYPE_CHIP=Glpi\Asset\AssetDefinition/Chip
GLPI_ITEMTYPE_CELULAR=Glpi\Asset\AssetDefinition/Celular
GLPI_ITEMTYPE_COLABORADOR=Glpi\Asset\AssetDefinition/Colaborador

# --- Opcional: sync agendado por pasta ---
# GLPI_SYNC_INPUT=/data/computers.csv

# --- Segurança (obrigatório em produção) ---
# Gere uma chave longa: openssl rand -hex 32
GLPI_API_KEY=
SPRING_PROFILES_ACTIVE=prod
# Swagger em produção (opcional; também exige X-API-Key): true ou false
GLPI_ENABLE_SWAGGER=false

# --- Porta exposta no host ---
SERVER_PORT=8081

# --- JVM (opcional) ---
# JAVA_TOOL_OPTIONS=-Xms256m -Xmx512m
