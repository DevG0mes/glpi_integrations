# Copie para .env na raiz do projeto (gitignored) ou exporte no shell.
# No Windows PowerShell:
#   $env:GLPI_APP_TOKEN="seu-app-token"
#   $env:GLPI_USER_TOKEN="seu-user-token"
#   $env:GLPI_API_BASE_URL="http://seu-servidor/apirest.php"

GLPI_API_STYLE=LEGACY_APIREST
GLPI_API_BASE_URL=http://localhost/apirest.php
GLPI_APP_TOKEN=
GLPI_USER_TOKEN=
GLPI_SYNC_INPUT=
